DATABASE_URL=postgresql://novel:novelpass@localhost:5433/novel
LLM_API_BASE=http://localhost:8080/v1
LLM_MODEL=qwen2.5-7b
LLM_API_KEY=local
# Optional OpenAI-compatible Groq free/developer-tier profile for local testing.
# Do not commit real API keys. Groq rate limits are model-specific and may change.
# Start with low max_tokens before running full chapter generation.
# LLM_API_BASE=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxx
# LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=qwen/qwen3-32b
# LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LLM_MODEL=openai/gpt-oss-120b
# Optional local 9Router profile. Run 9Router separately, then copy the API key
# from http://localhost:20128/dashboard. The OpenAI-compatible API base is:
# LLM_API_BASE=http://localhost:20128/v1
# LLM_API_KEY=9router_dashboard_key
# LLM_MODEL=kr/claude-sonnet-4.5
LLM_MAX_TOKENS=512
LLAMA_CONTEXT=16384
WORKER_FLOW_LANE=all
HISTORIAN_MCP_BASE_URL=http://localhost:8090
HISTORIAN_QDRANT_ENABLED=0
HISTORIAN_NEO4J_ENABLED=0
HISTORIAN_CONTEXT_EXTERNAL_ENABLED=0
HISTORIAN_CONTEXT_NEO4J_ENABLED=0
HISTORIAN_CONTEXT_QDRANT_ENABLED=0
HISTORIAN_CONTEXT_TIMEOUT_MS=350
HISTORIAN_CONTEXT_TOTAL_BUDGET_MS=800
HISTORIAN_CONTEXT_QDRANT_THRESHOLD=0.65
HISTORIAN_CONTEXT_QDRANT_TOP_K=12
HISTORIAN_CONTEXT_NEO4J_LIMIT=15
HISTORIAN_CONTEXT_CAST_LIMIT=12
HISTORIAN_CONTEXT_QDRANT_QUERY_CHARS=1000
# Set both to 1 when running qdrant + neo4j + historian-mcp-bridge containers.
# Optional for MCP bridge service (if you run it locally)
HISTORIAN_QDRANT_URL=http://localhost:6333
HISTORIAN_NEO4J_URI=bolt://localhost:7687
HISTORIAN_NEO4J_USER=neo4j
HISTORIAN_NEO4J_PASSWORD=novelgraphpass
NEXT_PUBLIC_MUSE_CHAT_ENABLED=0
LLM_COOL_OFF_SECONDS=5
LLM_TIMEOUT_SPLIT=180
LLM_TIMEOUT_FEEDBACK_SECONDS=20
PIPELINE_READY_STALLED_SECONDS=120
PIPELINE_MAX_RETRY_ATTEMPTS=8
# If false (default), forced_strategy runs cannot set allow_learning=true from API payloads.
ALLOW_FORCED_STRATEGY_LEARNING=false
# Shadow framework skeleton (safe by default: no write-path mutation)
AGENT_SHADOW_ENABLED=false
# Promotion guard powered by shadow evidence (opt-in block mode).
AGENT_PROMOTE_REQUIRE_SHADOW=false
AGENT_PROMOTE_SHADOW_MIN_SAMPLES=20
AGENT_PROMOTE_SHADOW_MAX_FAILURE_RATE_DELTA=0.01
AGENT_PROMOTE_SHADOW_MAX_LATENCY_DELTA_MS=250
# Taxonomy/rule-pack runtime version pair (must be compatible in DB map)
AGENT_TAXONOMY_VERSION=v1.0
AGENT_RULE_PACK_VERSION=rp1.0
# Optional explicit freeze window id (default uses current date YYYY-MM-DD)
AGENT_FREEZE_WINDOW_ID=
# Prompt hydration trace controls
AGENT_TRACE_STORE_PROMPT_TEXT=true
AGENT_TRACE_SPLIT_PROMPT_MAX_CHUNKS=40

# WRITING_ANALYSIS map-reduce chunking controls (to prevent long-chapter truncation/lost-in-middle)
WRITING_ANALYSIS_CHUNK_MAX_SCENES=3
WRITING_ANALYSIS_CHUNK_MAX_CHARS=5500
WRITING_ANALYSIS_MAX_CHUNKS=60
